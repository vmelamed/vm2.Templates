{
    "diff": {
        "tool": "diff",
        "command": "delta --side-by-side --line-numbers --paging never \"$LOCAL\" \"$REMOTE\""
    },
    "merge": {
        "tool": "code",
        "command": "code --new-window --wait --diff \"$REMOTE\" \"$LOCAL\""
    },
    "action_overrides": {
        "Directory.Build.props": "copy",
        "Directory.Packages.props": "copy"
    }
}
