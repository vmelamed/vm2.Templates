{
    "$schema": "https://json.schemastore.org/template",
    //
    // TEMPLATE METADATA - these are used primarily for display in template galleries and search results, but can also be used to conditionally include/exclude content in the template
    "identity": "vm2.Templates.AddNewPackage",
    "author": "Val Melamed",
    "classifications": [
        "vm2",
        "NuGet",
        "Package",
        "Repository",
        "GitHub",
        "GitHub Actions"
    ],
    "name": "vm2 NuGet Package Solution with GitHub Repository, Actions",
    "groupIdentity": "vm2.Templates",
    "tags": {
        "language": "C#",
        "type": "project"
    },
    "shortName": "vm2pkg",
    "postActions": [
        {
            "id": "run-repo-setup-again",
            "description": "Finish the configuration of the GitHub repository.",
            "actionId": "AC1156F7-BB77-4DB8-B28F-24EEBCCA1E5C",
            "manualInstructions": [
                {
                    "text": "To create the repository and set it up for CI/CD:\n1. Prepare the secrets:\n  - BENCHER_API_TOKEN\n  - CODECOV_TOKEN (create new for this repo only!)\n  - RELEASE_PAT\n  - REPORTGENERATOR_LICENSE\n  - NUGET_API_KEY\n  - GH_PACKAGES_TOKEN\n2. Run '$VM2_REPOS/vm2.DevOps/scripts/bash/repo-setup.sh' to possibly change some repo vars and to set the secrets."
                }
            ],
            "args": {
                "executable": "$VM2_REPOS/vm2.DevOps/scripts/bash/repo-setup.sh",
                "args": "--repo-name vm2.<NAME> --interactive-vars --interactive-secrets"
            }
        }
    ],
    // "constraints": {
    // },
    //
    // TEMPLATE SOURCE files configuration - these are the files that will be copied and processed to create the new project/solution. You can specify include/exclude patterns, conditional inclusion based on symbols, and renaming rules.
    "sources": [
        {
            "modifiers": [
                {
                    "exclude": [
                        "licenses/**",
                        "diff-shared.custom.json"
                    ]
                },
                {
                    "condition": "license == 'MIT'",
                    "include": [
                        "licenses/MIT.txt"
                    ],
                    "rename": {
                        "licenses/MIT.txt": "LICENSE"
                    }
                },
                {
                    "condition": "license == 'Apache-2.0'",
                    "include": [
                        "licenses/Apache-2.0.txt"
                    ],
                    "rename": {
                        "licenses/Apache-2.0.txt": "LICENSE"
                    }
                },
                {
                    "condition": "license == 'BSD-3'",
                    "include": [
                        "licenses/BSD-3-Clause.txt"
                    ],
                    "rename": {
                        "licenses/BSD-3-Clause.txt": "LICENSE"
                    }
                },
                {
                    "condition": "!(includeTests)",
                    "exclude": [
                        "test/**"
                    ]
                },
                {
                    "condition": "!(includeBenchmarks)",
                    "exclude": [
                        "benchmarks/**"
                    ]
                },
                {
                    "condition": "!(includeExamples)",
                    "exclude": [
                        "examples/**"
                    ]
                },
                {
                    "condition": "!(includeDocs)",
                    "exclude": [
                        "docs/**"
                    ]
                }
            ]
        }
    ],
    // "guids": [
    //     "MyPackage.csproj",
    //     "MyPackage.Tests.csproj"
    // ],
    "symbols": {
        "initialVersion": {
            "type": "parameter",
            "datatype": "string",
            "description": "Initial package version",
            "defaultValue": "0.0.0",
            "replaces": "{{initialVersion}}"
        },
        "license": {
            "type": "parameter",
            "datatype": "choice",
            "description": "License for the project",
            "defaultValue": "MIT",
            "replaces": "{{license}}",
            "choices": [
                {
                    "choice": "MIT",
                    "description": "MIT License"
                },
                {
                    "choice": "Apache-2.0",
                    "description": "Apache License 2.0"
                },
                {
                    "choice": "BSD-3",
                    "description": "BSD 3-Clause License"
                }
            ]
        },
        "includeTests": {
            "type": "parameter",
            "datatype": "bool",
            "description": "Include test project",
            "defaultValue": "true"
        },
        "includeBenchmarks": {
            "type": "parameter",
            "datatype": "bool",
            "description": "Include benchmarks project",
            "defaultValue": "true"
        },
        "includePackages": {
            "type": "parameter",
            "datatype": "bool",
            "description": "Include packable project",
            "defaultValue": "true"
        },
        "includeExamples": {
            "type": "parameter",
            "datatype": "bool",
            "description": "Include examples folder",
            "defaultValue": "true"
        },
        "includeDocs": {
            "type": "parameter",
            "datatype": "bool",
            "description": "Include docs folder",
            "defaultValue": "true"
        },
        "repositoryOrg": {
            "type": "parameter",
            "datatype": "string",
            "description": "GitHub organization/user",
            "defaultValue": "vmelamed",
            "replaces": "{{repositoryOrg}}"
        }
    },
    // "forms": [
    //     {
    //         "name": "Package Information",
    //         "fields": [
    //             {
    //                 "name": "initialVersion"
    //             },
    //             {
    //                 "name": "license"
    //             },
    //             {
    //                 "name": "includeBenchmarks"
    //             },
    //             {
    //                 "name": "includeExamples"
    //             },
    //             {
    //                 "name": "includeDocs"
    //             },
    //             {
    //                 "name": "repositoryOrg"
    //             }
    //         ]
    //     }
    // ],
    //
    // OUTPUT MANAGEMENT - specify the primary outputs of the template, which are the files that will be generated and can be used for post-processing actions. You can also specify custom output modifiers here if needed.
    "sourceName": "MyPackage",
    // *TODO*  the solution file and other artifacts have vm2. hardcoded as a prefix: vm2.MyPackage.slnx, vm2.MyPackage.csproj,
    // etc. When a user passes --name vm2.test1, MyPackage → vm2.test1 everywhere, so vm2.MyPackage → vm2.vm2.test1.
    // Double prefix. For now the solution is to pass `--name MyPackage --output vm2.MyPackage`.
    // Ideally the template should be smart enough to detect and avoid double prefixing.
    "preferNameDirectory": true,
    "primaryOutputs": [
        {
            "path": "src/MyPackage/MyPackage.csproj"
        },
        {
            "condition": "(includeTests)",
            "path": "test/MyPackage.Tests/MyPackage.Tests.csproj"
        },
        {
            "condition": "(includeBenchmarks)",
            "path": "benchmarks/MyPackage.Benchmarks/MyPackage.Benchmarks.csproj"
        },
        {
            "condition": "(includeDocs)",
            "path": "docs/README.md"
        },
        {
            "condition": "(includeExamples)",
            "path": "examples/Program.cs"
        },
        {
            "condition": "(includePackages)",
            "path": "src/MyPackage/MyPackage.csproj"
        }
    ],
    "specialCustomOperations": {
        "**/*.yaml": {
            "operations": [
                {
                    "type": "conditional",
                    "configuration": {
                        "if": [
                            "#if"
                        ],
                        "else": [
                            "#else"
                        ],
                        "elseif": [
                            "#elseif"
                        ],
                        "endif": [
                            "#endif"
                        ],
                        "evaluator": "C++",
                        "trim": true,
                        "wholeLine": true
                    }
                }
            ]
        },
        "**/*.yml": {
            "operations": [
                {
                    "type": "conditional",
                    "configuration": {
                        "if": [
                            "#if"
                        ],
                        "else": [
                            "#else"
                        ],
                        "elseif": [
                            "#elseif"
                        ],
                        "endif": [
                            "#endif"
                        ],
                        "evaluator": "C++",
                        "trim": true,
                        "wholeLine": true
                    }
                }
            ]
        }
    }
}
