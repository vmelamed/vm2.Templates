<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageType>Template</PackageType>
        <PackageId>vm2.Templates</PackageId>
        <TargetFramework>net10.0</TargetFramework>
        <Title>vm2 dotnet-new Templates</Title>
        <Description>dotnet-new templates for scaffolding vm2 NuGet packages.</Description>
        <PackageTags>dotnet-new;templates;vm2;nuget;package</PackageTags>
        <PackageProjectUrl>https://github.com/vmelamed/vm2.Templates</PackageProjectUrl>
        <PackageReadmeFile>README.md</PackageReadmeFile>

        <!-- Template packages have no compilable code -->
        <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <IncludeContentInPack>true</IncludeContentInPack>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <ContentTargetFolders>content</ContentTargetFolders>
        <NoDefaultExcludes>true</NoDefaultExcludes>
        <NoWarn>$(NoWarn);NU5128</NoWarn>

        <!-- Override inherited settings that don't apply to template packages -->
        <EnablePackageValidation>false</EnablePackageValidation>
        <IncludeSymbols>false</IncludeSymbols>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <IsTrimmable>false</IsTrimmable>
        <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    </PropertyGroup>

    <!-- Remove all inherited package references — template packages have no code dependencies -->
    <ItemGroup>
        <PackageReference Remove="@(PackageReference)" />
        <PackageReference Include="MinVer" PrivateAssets="all" />
        <Compile Remove="**\*"></Compile>
    </ItemGroup>

    <ItemGroup>
        <Content Include="templates/**/*" Exclude="templates/**/bin/**;templates/**/obj/**" />
        <None Include="README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

</Project>
